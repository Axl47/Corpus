# Database Configuration
# SQLite local file path (e.g. file:/app/data/local.db for Docker, file:local.db for local dev) or Turso url (libsql://...)
DATABASE_URL="file:local.db"
# Only required if using Turso Database
DATABASE_AUTH_TOKEN=""

# Auth.js v5 Configuration
# Generate a secure secret using: openssl rand -base64 33
AUTH_SECRET=""
# Required for running behind reverse proxies / containers
AUTH_TRUST_HOST=true

# MCP Settings
MCP_TOKEN_PREFIX="crps"

# Cloudinary (Required for icons/images/file uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Google OAuth Integration
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# GitHub OAuth Integration
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# PostHog Analytics (Optional)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# Absolute app URL used for invite links and auth redirects
NEXT_PUBLIC_APP_URL="http://localhost:3000"
